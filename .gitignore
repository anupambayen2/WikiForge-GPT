# WikiForge-GPT .gitignore
# =============================
# Excludes large data files, models, and generated content
# while keeping all source code and documentation

# ============================================================================
# LARGE DATA FILES (DO NOT UPLOAD)
# ============================================================================

# Raw Wikipedia data (multi-GB XML files)
data/raw/
F:/wiki_raw/

# Processed Wikipedia data
data/processed/
data/consolidated/

# Tokenized training data (18+ GB)
data/training/
data/validation/
data/test/

# Tokenizer files (keep these - they're small!)
# data/tokenizer/

# ============================================================================
# MODEL FILES (DO NOT UPLOAD - TOO LARGE)
# ============================================================================

# Model checkpoints (can be GBs)
models/checkpoints/
models/best/
models/pretrained/
models/exports/

# Temporary model files
*.pt
*.pth
*.ckpt
*.safetensors

# EXCEPTION: Keep final best model if small enough
!models/best/final_model.pt

# ============================================================================
# LOGS & OUTPUTS
# ============================================================================

# Training logs (can get very large)
logs/training/
logs/tensorboard/
logs/metrics/
logs/errors/

# Keep log directory structure but not contents
!logs/.gitkeep
!logs/training/.gitkeep
!logs/tensorboard/.gitkeep

# Generated outputs
outputs/predictions/
outputs/samples/
outputs/evaluations/
outputs/visualizations/

# Log files
*.log
*.jsonl

# ============================================================================
# PYTHON
# ============================================================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
.wikienv/
venv/
env/
ENV/
.venv/

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
*.manifest
*.spec

# Unit test / coverage
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# Jupyter Notebook
.ipynb_checkpoints
*.ipynb

# IPython
profile_default/
ipython_config.py

# ============================================================================
# CACHE & TEMPORARY FILES
# ============================================================================

# Cache directories
.cache/
cache/
temp/
tmp/
*.tmp

# PyTorch cache
.torch/

# Hugging Face cache
.huggingface/

# ============================================================================
# IDE & EDITOR FILES
# ============================================================================

# VSCode
.vscode/
*.code-workspace

# PyCharm
.idea/
*.iml

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
.\#*

# ============================================================================
# OPERATING SYSTEM FILES
# ============================================================================

# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
.directory
.Trash-*

# ============================================================================
# SECRETS & SENSITIVE DATA
# ============================================================================

# Environment variables
.env
.env.local
.env.*.local

# API keys
*_api_key.txt
secrets/
credentials/

# Personal notes (optional)
NOTES.md
TODO_private.md

# ============================================================================
# PROJECT-SPECIFIC
# ============================================================================

# Custom data paths (if using different drives)
E:/WikiForge-GPT/data/
F:/wiki_raw/

# Backup files
*.bak
*.backup

# Compressed archives (unless needed)
*.zip
*.tar.gz
*.rar
*.7z

# ============================================================================
# KEEP THESE IMPORTANT FILES (EXCEPTIONS)
# ============================================================================

# Keep empty directory structure
!data/.gitkeep
!models/.gitkeep
!logs/.gitkeep
!outputs/.gitkeep

# Keep documentation
!docs/
!README.md
!LICENSE
!CHANGELOG.md

# Keep configuration examples
!configs/
!*_example.py
!*_template.py

# Keep requirements
!requirements.txt
!environment.yml

# Keep small sample data (if any)
!data/samples/